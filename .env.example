# Liminal Screen - Environment Variables
# Copy this file to .env and update with your actual URLs

# Main screensaver content URL (must support autoplay media)
# This is the URL displayed when the screensaver activates
VITE_SAVER_URL=https://your-screensaver-content.com/content

# Debug screensaver URL (for development with devtools enabled)
# This version may include additional debugging features
VITE_SAVER_URL_DEBUG=https://your-screensaver-content.com/debug

# Options configuration form URL (must work offline)
# This is the remote page loaded in the Options window
VITE_OPTIONS_URL=https://your-options-site.com/options.html

# The name of the Liminal Screen App
#
VITE_APP_NAME="YourAppName"

# The description of the Liminal Screen App
#
VITE_APP_DESCRIPTION="Some description of the Your Liminal Screen App"

# Example URLs for testing:
# VITE_SAVER_URL=https://codepen.io/chriscoyier/full/gOmrYGW
# VITE_SAVER_URL_DEBUG=https://example.com/debug
# VITE_OPTIONS_URL=https://example.com/options
