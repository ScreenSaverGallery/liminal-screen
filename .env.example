# Liminal Screen - Environment Variables Template
# Copy this file to .env and customize for your organization

# =============================================================================
# App Identity (REQUIRED - change these for your fork)
# =============================================================================

# The name of your application (displayed in window titles, menus, about dialog)
# CHANGE THIS to your product name
VITE_APP_NAME=Your App Name

# The description of your application (used in bundle metadata)
# CHANGE THIS to describe your product
VITE_APP_DESCRIPTION=Your app description here

# =============================================================================
# Screensaver URLs (REQUIRED)
# =============================================================================

# Main screensaver content URL (must support autoplay media)
# This is the URL displayed when the screensaver activates
VITE_SAVER_URL=https://save.screensaver.gallery

# Debug screensaver URL (for development with devtools enabled)
VITE_SAVER_URL_DEBUG=https://save.screensaver.gallery/debug

# Options configuration form URL (optional, can be local file or remote)
# VITE_OPTIONS_URL=https://your-domain.com/options.html

# =============================================================================
# Default Timing Values (optional - users can override in UI)
# =============================================================================

# Minutes of inactivity before screensaver activates (default: 0.2 = 12 seconds)
VITE_DEFAULT_STARTS_IN=0.2

# Minutes before display turns off (default: 1 = 60 seconds)
VITE_DEFAULT_DISPLAY_OFF_IN=1

# Minutes after which password is required (0 = no password)
VITE_DEFAULT_REQUIRE_PASS_IN=1

# Whether to run screensaver on battery power (true/false)
VITE_DEFAULT_RUN_ON_BATTERY=false

# Enable debug mode (true/false)
VITE_DEFAULT_DEBUG=false
