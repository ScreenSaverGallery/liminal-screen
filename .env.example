# Liminal Screen - Environment Variables Template
# Copy this file to .env and customize for your organization

# =============================================================================
# App Identity (REQUIRED - change these for your fork)
# =============================================================================

# The name of your application (displayed in window titles, menus, about dialog)
# CHANGE THIS to your product name
VITE_APP_NAME="Your App Name"

# The description of your application (used in bundle metadata)
# CHANGE THIS to describe your product
VITE_APP_DESCRIPTION="Your app description here"

# Semantic version of your application (must be valid semver, e.g. 1.0.0)
# Used as the bundle version on all platforms
VITE_APP_VERSION="0.1.0"

# Unique application identifier in reverse-domain notation (e.g. com.example.myapp)
# MUST be unique per fork — used as the bundle ID and webview data directory key.
# Only alphanumeric characters, hyphens, and periods are allowed.
# CHANGE THIS for your fork — collisions cause data-directory conflicts on install.
VITE_APP_IDENTIFIER="com.example.your-app"

# =============================================================================
# Screensaver URLs (REQUIRED)
# =============================================================================

# Main screensaver content URL (must support autoplay media)
# This is the URL displayed when the screensaver activates
VITE_SAVER_URL="https://tomaszatoo.github.io/liminal-screen/"

# Debug screensaver URL (for development with devtools enabled)
VITE_SAVER_URL_DEBUG="https://tomaszatoo.github.io/liminal-screen/?debug=true"

# Options configuration form URL (optional, can be local file or remote)
# VITE_OPTIONS_URL=https://your-domain.com/options.html

# =============================================================================
# Default Timing Values (optional - users can override in UI)
# =============================================================================

# Minutes of inactivity before screensaver activates (default: 0.2 = 12 seconds)
VITE_DEFAULT_STARTS_IN=0.2

# Minutes before display turns off (default: 1 = 60 seconds)
VITE_DEFAULT_DISPLAY_OFF_IN=1

# Minutes after which password is required (0 = no password)
VITE_DEFAULT_REQUIRE_PASS_IN=1

# Whether to run screensaver on battery power (true/false)
VITE_DEFAULT_RUN_ON_BATTERY=false

# Enable debug mode (true/false)
VITE_DEFAULT_DEBUG=false

# =============================================================================
# Notifications — remote feed polling (optional)
# =============================================================================

# JSON feed of notifications to show as OS banners. Empty = disabled.
# Format: [{ "id": "...", "title": "...", "body": "...", "url": "..." }]
VITE_NOTIFICATION_URL=

# How often to poll the feed, in seconds (minimum 60, default 3600 = 1 hour)
VITE_NOTIFICATION_CHECK_INTERVAL_SECS=3600

# Default user consent for notifications (true/false). Users toggle this in
# the options window ("Allow Notifications"); notifications are opt-in, so
# leave this false unless your deployment has separate consent handling.
VITE_DEFAULT_NOTIFICATIONS_ENABLED=false

# =============================================================================
# Updater (REQUIRED if using the Tauri updater plugin)
# These are loaded into tauri.conf.json at build time via ${{ env.VAR }}.
# Generate a keypair with: `bun tauri signer generate -w ~/.tauri/your-app.key`
# Then paste the PUBLIC key here and keep the private key safe (CI secret).
# =============================================================================

# Public key (PEM) used to verify update signatures. Paste the FULL PEM,
# including the BEGIN/END lines. Multi-line values are supported when the
# entire value is wrapped in double quotes (dotenv/Tauri parse them verbatim).
VITE_UPDATER_PUBKEY="-----BEGIN PUBLIC KEY-----
 paste your public key here (multi-line is fine inside quotes)
-----END PUBLIC KEY-----"

# URL serving the latest.json manifest consumed by the updater.
# For GitHub releases, point at .../releases/latest/download/latest.json
VITE_UPDATER_ENDPOINT="https://github.com/your-org/your-app/releases/latest/download/latest.json"
