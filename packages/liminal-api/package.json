{
  "name": "@liminal-screen/api",
  "version": "0.1.0",
  "description": "IPC bridge for Liminal Screen remote options pages. Works as npm package or CDN script.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "bun run build:esm && bun run build:iife && bun run build:types",
    "build:esm": "bun build src/index.ts --outfile=dist/index.js --format=esm --target=browser",
    "build:iife": "bun build src/index.ts --outfile=dist/liminal-api.global.js --format=iife --target=browser",
    "build:types": "tsc --emitDeclarationOnly --declarationMap --outDir dist",
    "dev": "tsc --watch --emitDeclarationOnly --declarationMap --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "liminal-screen",
    "screensaver",
    "tauri",
    "ipc",
    "options"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0"
  }
}
